{
  "info": {
    "name": "CIS API - Full Testing",
    "_postman_id": "6e8aa15d-2f8c-4f41-9b13-4af7e90f0012",
    "description": "Coleccion para validar api-cis + user-management-ms. Cubre topics (incl. allowComments/anonymousVote), ideas (soft delete), comentarios, votos, estadisticas y health. JWT requiere claims sub y role (ver docs/auth-contract.md).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('seed')) {",
          "  pm.collectionVariables.set('seed', Date.now().toString());",
          "}",
          "if (!pm.collectionVariables.get('rnd')) {",
          "  pm.collectionVariables.set('rnd', Math.floor(Math.random() * 100000).toString());",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 - Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{cisBaseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Tiene campo status', () => pm.expect(json).to.have.property('status'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Auth (user-management-ms)",
      "item": [
        {
          "name": "POST /v1/auth/login (usuario principal)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{login}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{usersBaseUrl}}/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Respuesta tiene token', () => pm.expect(json.token).to.be.a('string').and.not.empty);",
                  "pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /v1/auth/login (usuario secundario)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{otherLogin}}\",\n  \"password\": \"{{otherPassword}}\"\n}"
            },
            "url": "{{usersBaseUrl}}/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login secundario 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('otherToken', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /v1/auth/login (credenciales invalidas)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{login}}\",\n  \"password\": \"incorrecta\"\n}"
            },
            "url": "{{usersBaseUrl}}/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login inválido retorna 401/400', () => pm.expect(pm.response.code).to.be.oneOf([400,401]));"
                ]
              }
            }
          ]
        }
      ]
    },
