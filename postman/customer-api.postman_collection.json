    {
      "name": "05 - Users - DELETE",
      "item": [
        {
          "name": "DELETE /v1/users/:id - Eliminar usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204 No Content', () => pm.response.to.have.status(204));",
                  "pm.test('Body vacio', () => pm.expect(pm.response.text()).to.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users", "{{userId}}"]
            },
            "description": "Elimina el usuario con el ID guardado en la coleccion. Requiere token JWT de ADMIN u OWNER. Devuelve 204 sin body."
          }
        },
        {
          "name": "DELETE /v1/users/:id - ID inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/users/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Intenta eliminar un UUID inexistente. Espera 404 Not Found."
          }
        },
        {
          "name": "DELETE /v1/users/:id - Sin permiso (403)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const baseUrl = pm.environment.get('baseUrl');",
                  "const userLogin = pm.environment.get('userLogin');",
                  "const userPassword = pm.environment.get('userPassword');",
                  "pm.sendRequest({",
                  "  url: baseUrl + '/v1/auth/login',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json' },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ login: userLogin, password: userPassword }) }",
                  "}, (err, res) => {",
                  "  if (!err && res.code === 200) {",
                  "    pm.environment.set('tokenUser', res.json().token);",
                  "  }",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{tokenUser}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users", "{{userId}}"]
            },
            "description": "Intenta eliminar un usuario usando un token de rol USER (sin permiso). Espera 403 Forbidden. Requiere establecer `tokenUser` manualmente con un JWT de rol USER."
          }
        }
      ]
    }
  ]
