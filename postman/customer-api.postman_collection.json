{
  "info": {
    "name": "Customer API - User Management",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Coleccion Postman para customer-api (user-management-ms). Cubre autenticacion JWT y operaciones CRUD completas sobre usuarios. El token se extrae automaticamente al hacer login y se aplica en todas las requests protegidas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "POST /v1/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Respuesta tiene token', () => pm.expect(json.token).to.be.a('string').and.not.empty);",
                  "pm.test('Tipo es Bearer', () => pm.expect(json.type).to.eql('Bearer'));",
                  "pm.test('Tiene rol', () => pm.expect(json.role).to.be.oneOf(['ADMIN', 'OWNER', 'USER']));",
                  "pm.environment.set('token', json.token);",
                  "pm.collectionVariables.set('userId', '');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{login}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "login"]
            },
            "description": "Autentica un usuario y devuelve un JWT. El token se guarda automaticamente en la variable de coleccion `token`."
          }
        },
        {
          "name": "POST /v1/auth/login - Credenciales invalidas",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"usuario_inexistente\",\n  \"password\": \"password_incorrecta\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "auth", "login"]
            },
            "description": "Verifica que credenciales invalidas devuelvan 401 Unauthorized."
          }
        }
      ]
    },
    {
      "name": "02 - Users - CREATE",
      "item": [
        {
          "name": "POST /v1/users - Crear usuario ADMIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Tiene id', () => pm.expect(json.id).to.be.a('string').and.not.empty);",
                  "pm.test('Nombre correcto', () => pm.expect(json.name).to.eql('Test Admin'));",
                  "pm.test('Login correcto', () => pm.expect(json.login).to.be.a('string'));",
                  "pm.test('Rol es ADMIN', () => pm.expect(json.role).to.eql('ADMIN'));",
                  "pm.test('No expone password', () => pm.expect(json).to.not.have.property('password'));",
                  "pm.environment.set('userId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Admin\",\n  \"login\": \"testadmin_{{$timestamp}}\",\n  \"password\": \"Admin@1234\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users"]
            },
            "description": "Crea un nuevo usuario con rol ADMIN. Requiere token JWT de un ADMIN u OWNER. El id generado se guarda en `userId`."
          }
        },
