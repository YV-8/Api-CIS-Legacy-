      ]
    },
    {
      "name": "03 - Users - READ",
      "item": [
        {
          "name": "GET /v1/users - Listar todos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Respuesta es array', () => pm.expect(json).to.be.an('array'));",
                  "pm.test('Elementos tienen id, name, login, role', () => {",
                  "  if (json.length > 0) {",
                  "    pm.expect(json[0]).to.have.all.keys('id', 'name', 'login', 'role');",
                  "    pm.expect(json[0]).to.not.have.property('password');",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users"]
            },
            "description": "Obtiene la lista de todos los usuarios. Requiere token JWT. Accesible para USER, ADMIN y OWNER."
          }
        },
        {
          "name": "GET /v1/users/:id - Obtener por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('ID coincide', () => pm.expect(json.id).to.eql(pm.environment.get('userId')));",
                  "pm.test('Tiene campos requeridos', () => pm.expect(json).to.have.all.keys('id', 'name', 'login', 'role'));",
                  "pm.test('No expone password', () => pm.expect(json).to.not.have.property('password'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users", "{{userId}}"]
            },
            "description": "Obtiene un usuario por su UUID. Usa el `userId` guardado en la coleccion. Requiere token JWT."
          }
        },
