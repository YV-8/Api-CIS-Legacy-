    {
      "name": "04 - Users - UPDATE",
      "item": [
        {
          "name": "PUT /v1/users/:id - Actualizar nombre",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Nombre actualizado', () => pm.expect(json.name).to.eql('Nombre Actualizado'));",
                  "pm.test('ID no cambia', () => pm.expect(json.id).to.eql(pm.environment.get('userId')));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nombre Actualizado\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users", "{{userId}}"]
            },
            "description": "Actualiza solo el nombre del usuario. Todos los campos son opcionales (PATCH semantics). Requiere token JWT de ADMIN, OWNER o USER."
          }
        },
