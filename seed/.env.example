# ─── Conexión MySQL ───────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3307
DB_NAME=sd3
DB_USER=SOME_USER
DB_PASSWORD=SOME_PASSWORD

# ─── Conexión MongoDB (usado por migrate.py) ──────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=sd3

# ─── Volumen de registros por tabla (seed.py) ─────────────────────────────────
USERS_COUNT=7000
TOPICS_COUNT=7000
IDEAS_COUNT=7000
VOTES_COUNT=7000
COMMENTS_COUNT=14000

# ─── Tamaño del lote de inserción (filas por INSERT) ──────────────────────────
BATCH_SIZE=500
